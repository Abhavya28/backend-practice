<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Posts</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Posts</h1>
    <% for(post of posts){ %>
        <div>
            <h2>@<%= post.username %></h2>
            <p><%= post.content %></p>
            <a href="http://localhost:8080/posts/<%=post.id%>">See in detail</a>
            <a href="http://localhost:8080/posts/<%=post.id%>/edit">Edit Post</a>
            <form method="POST" action="/posts/<%=post.id%>?_method=DELETE">
                <button>Delete Post</button>
            </form>
            
            <hr>
        </div>
    <% } %>
    <br>

    <button><a href="http://localhost:8080/posts/new">New Post</a></button>
</body>
</html>